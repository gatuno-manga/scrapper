COMPOSE_FILE=docker-compose.dev.yml

# Scraper Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=scraper-microservice

# Storage
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=rustfsadmin
STORAGE_SECRET_KEY=rustfsadmin
STORAGE_REGION=us-east-1
STORAGE_SSL=false

# Browser & Anti-Bot
BROWSER_URL=ws://localhost:3002
FLARESOLVERR_URL=http://localhost:8191

# Kafka Topics - Requests
TOPIC_CHAPTER_REQUESTED=scraping.chapter.requested
TOPIC_NEW_BOOK_REQUESTED=scraping.new-book.requested
TOPIC_UPDATE_BOOK_REQUESTED=scraping.update-book.requested
TOPIC_COVERS_REQUESTED=scraping.covers.requested
TOPIC_IMAGES_REQUESTED=scraping.images.requested
TOPIC_TEST_REQUESTED=scraping.test

# Kafka Topics - Completions
TOPIC_CHAPTER_COMPLETED=scraping.chapter.completed
TOPIC_CHAPTER_FAILED=scraping.chapter.failed
TOPIC_BOOK_COMPLETED=scraping.new-book.completed
TOPIC_UPDATE_BOOK_COMPLETED=scraping.update-book.completed
TOPIC_COVERS_COMPLETED=scraping.covers.completed
TOPIC_IMAGE_PROCESSING=image.processing.requested

# Kafka Resilience
KAFKA_WRITE_TIMEOUT=20
KAFKA_READ_TIMEOUT=20
KAFKA_REQUIRED_ACKS=1
KAFKA_DEBUG=false

# Resource Management
BROWSER_POOL_SIZE=1
CACHE_MAX_SIZE_MB=100
